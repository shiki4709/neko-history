# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
venv/

# Config with secrets
config/settings.yaml

# Generated outputs
output/*/shorts/*/clips/
output/*/shorts/*/images/
output/*/shorts/*/*.mp3
output/*/shorts/*/*.mp4
output/*/longform/*/clips/
